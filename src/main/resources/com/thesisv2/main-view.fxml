<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.thesisv2.Controller">
   <top>
      <VBox fx:id="TopBar" BorderPane.alignment="CENTER">
         <children>
            <MenuBar fx:id="MainMenuBar" style="-fx-background-color: #ffffff;" VBox.vgrow="ALWAYS">
              <menus>
                <Menu fx:id="FileMenu" mnemonicParsing="false" text="Αρχείο">
                  <items>
                    <MenuItem mnemonicParsing="false" text="Close" />
                  </items>
                </Menu>
                <Menu fx:id="EditMenu" mnemonicParsing="false" text="Επεξεργασία">
                  <items>
                    <MenuItem fx:id="EditDelete" mnemonicParsing="false" text="Διαγραφή" />
                        <MenuItem fx:id="EditDuplicate" mnemonicParsing="false" text="Κλωνοποίηση" />
                        <MenuItem fx:id="EditNew" mnemonicParsing="false" text="Καταχώριση" />
                        <MenuItem fx:id="EditEdit" mnemonicParsing="false" text="Επεξεργασία" />
                        <MenuItem fx:id="EditMassNew" mnemonicParsing="false" text="Μαζική καταχώριση" />
                        <MenuItem fx:id="EditMassEdit" mnemonicParsing="false" text="Μαζική επεξεργασία" />
                  </items>
                </Menu>
                  <Menu fx:id="SettingsMenu" mnemonicParsing="false" text="Ρυθμίσεις">
                    <items>
                      <MenuItem mnemonicParsing="false" text="Settings" />
                    </items>
                  </Menu>
                <Menu fx:id="HelpMenu" mnemonicParsing="false" text="Help" />
                  <Menu fx:id="AboutMenu" mnemonicParsing="false" text="About" />
              </menus>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </MenuBar>
            <MenuBar fx:id="SecondMenuBar" style="-fx-background-color: #eeeeee;" VBox.vgrow="ALWAYS">
              <menus>
                <Menu fx:id="ListaEidon" mnemonicParsing="false" text="Λίστα ειδών" />
                <Menu fx:id="ListaApothikon" mnemonicParsing="false" text="Λίστα αποθηκών" />
                <Menu fx:id="EkdosiParastatikou" mnemonicParsing="false" text="Έκδοση παραστατικού" />
                  <Menu fx:id="Endodiakinisi" mnemonicParsing="false" text="Ενδοδιακίνηση" />
                  <Menu fx:id="ListaKiniseon" mnemonicParsing="false" text="Λίστα κινήσεων" />
                  <Menu fx:id="ListaParastatikon" mnemonicParsing="false" text="Λίστα παραστατικών" />
              </menus>
            </MenuBar>
         </children>
      </VBox>
   </top>
   <left>
      <VBox fx:id="SideBar" BorderPane.alignment="CENTER" />
   </left>
   <bottom>
      <HBox alignment="BOTTOM_LEFT" prefWidth="1280.0" BorderPane.alignment="CENTER">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="TEST" />
            <Region HBox.hgrow="ALWAYS" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="MORE TEST" />
         </children>
      </HBox>
   </bottom>
   <center>
      <SplitPane dividerPositions="0.1" BorderPane.alignment="CENTER">
        <items>
            <VBox prefHeight="600.0" style="-fx-background-color: #eeeeee;">
               <children>
                  <Label text="Κωδικός">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="SearchCode">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </TextField>
                  <Label text="Περιγραφή">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="SearchDescription" />
                  <Label text="Αποθήκη">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="SearchWarehouse" />
                  <Label text="Τεμάχια">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="SearchStock" />
                  <Label text="Εναλλακτικός">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="SearchAll" />
               </children>
            </VBox>
            <TableView fx:id="ProductTableView">
              <columns>
                <TableColumn fx:id="ColumnProductID" prefWidth="82.0" text="Κωδικός" />
                <TableColumn fx:id="ColumnProductDescription" prefWidth="134.0" text="Περιγραφή" />
                  <TableColumn fx:id="ColumnWarehouses" prefWidth="64.0" text="Αποθήκες" />
                  <TableColumn fx:id="ColumnPurchasePrice" prefWidth="91.0" text="Τιμή αγωράς" />
                  <TableColumn fx:id="ColumnSellPrice" prefWidth="92.0" text="Τιμή λιανικής" />
                  <TableColumn fx:id="ColumnWholesalePrice" prefWidth="97.0" text="Τιμή χονδρικής" />
                  <TableColumn fx:id="ColumnStock" prefWidth="73.0" text="Απόθεμα" />
                  <TableColumn fx:id="ColumnPallets" prefWidth="110.0" text="Παλέτες ατόφιες" />
                  <TableColumn fx:id="ColumnOutofpallet" prefWidth="126.0" text="Τεμ. εκτώς παλέτας" />
                  <TableColumn fx:id="ColumnPalletsize" prefWidth="107.0" text="Τεμ. ανα παλέτα" />
              </columns>
            </TableView>
        </items>
      </SplitPane>
   </center>
</BorderPane>
